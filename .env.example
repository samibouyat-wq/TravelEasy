# === APPLICATION ===
APP_ENV=development
DEBUG=true
SECRET_KEY=change_me_to_a_long_random_secret_key
ALLOWED_HOSTS=localhost,127.0.0.1

# === BASE DE DONNÉES ===
POSTGRES_USER=ouicooly
POSTGRES_PASSWORD=ouicooly_password
POSTGRES_DB=ouicooly_db
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://ouicooly:ouicooly_password@db:5432/ouicooly_db

# === REDIS ===
REDIS_URL=redis://redis:6379/0

# === FIREBASE AUTH ===
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY_ID=your_private_key_id
FIREBASE_PRIVATE_KEY=your_private_key
FIREBASE_CLIENT_EMAIL=your_client_email
FIREBASE_CLIENT_ID=your_client_id
FIREBASE_WEB_API_KEY=your_web_api_key

# === STRIPE ===
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# === OPENAI ===
OPENAI_API_KEY=sk-your_openai_api_key
OPENAI_MODEL=gpt-4-turbo-preview

# === SNCF ===
SNCF_API_KEY=your_sncf_api_key
SNCF_API_BASE_URL=https://api.sncf.com/v1

# === AMADEUS (VOLS) ===
AMADEUS_API_KEY=your_amadeus_api_key
AMADEUS_API_SECRET=your_amadeus_api_secret
AMADEUS_BASE_URL=https://test.api.amadeus.com

# === BOOKING.COM / EXPEDIA ===
BOOKING_API_KEY=your_booking_api_key
BOOKING_API_BASE_URL=https://distribution-xml.booking.com/2.0

# === GOOGLE MAPS ===
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# === OPENWEATHERMAP ===
OPENWEATHER_API_KEY=your_openweathermap_api_key

# === AWS S3 (optionnel) ===
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=your_s3_bucket_name
AWS_REGION=eu-west-3

# === FRONTEND (Flutter Web) ===
FLUTTER_WEB_PORT=3000
